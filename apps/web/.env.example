# EODHD API key — required for price fetching (manual refresh button)
# Free tier: 20 API calls/day. Sign up at https://eodhd.com/register
EODHD_API_KEY=your_key_here

# IB Client Portal Gateway URL (optional — only needed if using IB integration)
# Run the gateway locally: docker run -p 5000:5000 ghcr.io/gnzsnz/ib-gateway:stable
# Then log in at https://localhost:5000 in your browser
IB_GATEWAY_URL=https://localhost:5000/v1/api

# Supabase — required for data persistence in non-mock mode
# Create a project at https://supabase.com, then copy URL and anon key from Settings > API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...
