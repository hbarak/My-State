{
  "name": "house-budget-stock-tracker",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @my-stocks/web",
    "dev:mock": "npm run dev:mock -w @my-stocks/web",
    "build:web": "npm run build -w @my-stocks/web",
    "typecheck": "npm run typecheck -w @my-stocks/web && npm run typecheck -w @my-stocks/api",
    "test": "npm run test -w @my-stocks/domain",
    "test:api": "npm run test -w @my-stocks/api",
    "test:adapters": "npm run test:adapters -w @my-stocks/web",
    "test:e2e": "npm run test:e2e -w @my-stocks/web",
    "test:e2e:mock": "npm run test:e2e:mock -w @my-stocks/web"
  },
  "devDependencies": {
    "@esbuild/darwin-x64": "^0.27.4",
    "@vitest/browser": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.2"
  },
  "dependencies": {
    "@rolldown/binding-darwin-x64": "^1.0.0-rc.14"
  }
}
